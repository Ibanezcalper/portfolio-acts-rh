---
import conceptosData from "../../public/conceptos.json";
---

<div
    class="relative pt-16 pb-24 px-6 bg-slate-900 overflow-hidden"
    id="match-expert"
    data-conceptos={JSON.stringify(conceptosData)}
>
    <!-- Dark Game Background -->
    <div class="absolute inset-0 opacity-20 pointer-events-none">
        <div
            class="absolute inset-0 bg-[radial-gradient(#3b82f6_1px,transparent_1px)] [background-size:40px_40px]"
        >
        </div>
    </div>

    <div class="max-w-6xl mx-auto relative z-10">
        <header class="text-center mb-12">
            <span
                class="inline-block px-4 py-1.5 bg-blue-500/10 text-blue-400 rounded-full text-[10px] font-black uppercase tracking-[0.2em] mb-4"
            >
                Desafío de Correspondencia
            </span>
            <h2
                class="text-4xl md:text-5xl font-black text-white tracking-tighter mb-4 leading-none"
            >
                Une las <span class="italic text-blue-500">Parejas</span>
            </h2>
            <p
                class="text-slate-400 font-medium max-w-xl mx-auto text-sm md:text-base"
            >
                Arrastra los términos superiores a su definición correspondiente
                o haz clic para seleccionar.
            </p>
        </header>

        <!-- Terms Dock (Top Bar) -->
        <div class="mb-12">
            <div
                id="terms-dock"
                class="flex flex-wrap justify-center gap-3 p-6 bg-slate-800/50 rounded-[2.5rem] border border-white/5 min-h-[100px] shadow-inner"
            >
                <!-- JS Populated Draggable Terms -->
            </div>
        </div>

        <!-- Matching Board -->
        <div
            id="matching-board"
            class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-4"
        >
            <!-- JS Populated: [Slot] [Definition] -->
        </div>

        <div class="mt-16 flex flex-col items-center gap-8">
            <div
                class="flex items-center gap-4 bg-slate-800/80 p-2 rounded-2xl border border-white/10 shadow-xl"
            >
                <div
                    class="px-6 py-2 bg-slate-900 rounded-xl font-mono text-xl font-bold text-blue-400"
                    id="timer-match"
                >
                    00:00
                </div>
                <button
                    id="submit-match"
                    class="px-10 py-3 bg-blue-600 hover:bg-blue-500 text-white font-black rounded-xl transition-all shadow-lg shadow-blue-900/40 active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed"
                >
                    ENVIAR RESPUESTAS
                </button>
                <button
                    id="reset-match"
                    class="p-3 bg-slate-700 hover:bg-slate-600 text-white rounded-xl transition-all active:rotate-180"
                    title="Reiniciar"
                >
                    <svg
                        class="w-5 h-5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2.5"
                            d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
                        ></path></svg
                    >
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Victory/Result Modal -->
<div
    id="result-modal-match"
    class="fixed inset-0 z-[200] bg-slate-950/80 backdrop-blur-xl flex items-center justify-center opacity-0 pointer-events-none transition-all duration-500"
>
    <div
        class="bg-white p-10 rounded-[3rem] shadow-2xl text-center max-w-sm mx-auto transform scale-90 transition-all duration-500"
    >
        <div
            id="result-icon-match"
            class="w-20 h-20 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-6 text-3xl"
        >
            🏆
        </div>
        <h4
            id="result-title-match"
            class="text-3xl font-black text-slate-900 mb-2"
        >
            ¡EXCELENTE!
        </h4>
        <p id="result-msg-match" class="text-slate-500 font-medium mb-8">
            Has logrado unir todas las parejas correctamente.
        </p>
        <button
            id="close-modal-match"
            class="w-full py-4 bg-blue-600 text-white rounded-2xl font-black hover:bg-blue-700 transition-all shadow-xl shadow-blue-900/20"
            >CONTINUAR</button
        >
    </div>
</div>

<style is:global>
    .match-card {
        padding: 10px 18px;
        background: #1e293b;
        border: 2px solid #334155;
        border-radius: 14px;
        color: white;
        font-weight: 800;
        font-size: 0.85rem;
        cursor: grab;
        transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        user-select: none;
        touch-action: none;
        box-shadow: 0 4px 0 #0f172a;
        text-transform: uppercase;
    }
    .match-card:hover {
        background: #334155;
        transform: translateY(-2px);
    }
    .match-card.dragging {
        opacity: 0.4;
        cursor: grabbing;
    }
    .match-card.selected {
        background: #3b82f6 !important;
        border-color: #60a5fa !important;
        box-shadow: 0 0 15px rgba(59, 130, 246, 0.5);
        transform: scale(1.05);
    }
    .match-card.placed {
        width: 100%;
        height: 100%;
        margin: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: none;
        border: none;
        background: transparent;
    }

    .match-slot {
        width: 140px;
        height: 54px;
        background: rgba(15, 23, 42, 0.4);
        border: 2px dashed #475569;
        border-radius: 14px;
        transition: all 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
    .match-slot.over {
        border-color: #3b82f6;
        background: rgba(59, 130, 246, 0.1);
    }
    .match-slot.filled {
        border-style: solid;
        border-color: #334155;
        background: #1e293b;
        box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.2);
    }
    .match-slot.correct {
        border-color: #10b981 !important;
        background: #064e3b !important;
    }
    .match-slot.wrong {
        border-color: #ef4444 !important;
        background: #451a1a !important;
    }

    .match-def {
        font-size: 0.95rem;
        font-weight: 500;
        color: #94a3b8;
        line-height: 1.4;
    }
</style>

<script>
    (function () {
        const container = document.getElementById("match-expert");
        if (!container) return;
        const poolData = JSON.parse(
            container.getAttribute("data-conceptos") || "[]",
        );

        const dock = document.getElementById("terms-dock");
        const board = document.getElementById("matching-board");
        const submitBtn = document.getElementById(
            "submit-match",
        ) as HTMLButtonElement;
        const resetBtn = document.getElementById("reset-match");
        const timerE = document.getElementById("timer-match");
        const modal = document.getElementById("result-modal-match");

        let startTime: number | null = null;
        let timerInt: any = null;
        let selectedId: string | null = null;
        const TOTAL = 6;
        let activePairs: any[] = [];

        function init() {
            clearInterval(timerInt);
            if (timerE) timerE.textContent = "00:00";
            startTime = null;
            selectedId = null;
            if (dock) dock.innerHTML = "";
            if (board) board.innerHTML = "";
            if (submitBtn) submitBtn.disabled = false;
            hideModal();

            activePairs = [...poolData]
                .sort(() => 0.5 - Math.random())
                .slice(0, TOTAL);

            const shuffledTerms = [...activePairs].sort(
                () => 0.5 - Math.random(),
            );
            const shuffledDefs = [...activePairs].sort(
                () => 0.5 - Math.random(),
            );

            shuffledTerms.forEach((item) => {
                const card = document.createElement("div");
                card.className = "match-card";
                card.textContent = item.termino;
                card.draggable = true;
                card.dataset.id = item.termino;

                card.addEventListener("dragstart", (e) => {
                    startTimer();
                    card.classList.add("dragging");
                    e.dataTransfer?.setData("text/plain", item.termino);
                });
                card.addEventListener("dragend", () =>
                    card.classList.remove("dragging"),
                );

                card.addEventListener("click", () => {
                    startTimer();
                    document
                        .querySelectorAll(".match-card")
                        .forEach((c) => c.classList.remove("selected"));
                    if (selectedId === item.termino) {
                        selectedId = null;
                    } else {
                        selectedId = item.termino;
                        card.classList.add("selected");
                    }
                });

                dock?.appendChild(card);
            });

            shuffledDefs.forEach((item) => {
                const row = document.createElement("div");
                row.className =
                    "flex items-center gap-6 p-4 rounded-2xl transition-all hover:bg-white/5";

                const slot = document.createElement("div");
                slot.className = "match-slot";
                slot.dataset.targetId = item.termino;

                slot.addEventListener("dragover", (e) => {
                    e.preventDefault();
                    slot.classList.add("over");
                });
                slot.addEventListener("dragleave", () =>
                    slot.classList.remove("over"),
                );
                slot.addEventListener("drop", (e) => {
                    if (slot.classList.contains("locked")) return;
                    e.preventDefault();
                    slot.classList.remove("over");
                    const id = e.dataTransfer?.getData("text/plain");
                    if (id) placeTerm(id, slot);
                });

                slot.addEventListener("click", () => {
                    if (slot.classList.contains("locked")) return;
                    if (selectedId) {
                        placeTerm(selectedId, slot);
                        selectedId = null;
                        document
                            .querySelectorAll(".match-card")
                            .forEach((c) => c.classList.remove("selected"));
                    }
                });

                const defText = document.createElement("div");
                defText.className = "match-def";
                defText.textContent = item.definicion;

                row.appendChild(slot);
                row.appendChild(defText);
                board?.appendChild(row);
            });
        }

        function placeTerm(id: string, slot: HTMLElement) {
            if (slot.classList.contains("locked")) return;
            // If slot already has one, return it to dock
            const existing = slot.querySelector(".match-card");
            if (existing) {
                const oldId = (existing as HTMLElement).dataset.id;
                returnToDock(oldId!);
            }

            // Remove from dock or other slot
            const original = container?.querySelector(
                `.match-card[data-id="${id}"]`,
            );
            original?.remove();

            // Create placed card
            const placed = document.createElement("div");
            placed.className = "match-card placed";
            placed.textContent = id;
            placed.dataset.id = id;

            slot.innerHTML = "";
            slot.appendChild(placed);
            slot.classList.add("filled");
        }

        function returnToDock(id: string) {
            const card = document.createElement("div");
            card.className = "match-card";
            card.textContent = id;
            card.draggable = true;
            card.dataset.id = id;
            card.addEventListener("dragstart", (e) => {
                card.classList.add("dragging");
                e.dataTransfer?.setData("text/plain", id);
            });
            card.addEventListener("dragend", () =>
                card.classList.remove("dragging"),
            );
            card.addEventListener("click", () => {
                document
                    .querySelectorAll(".match-card")
                    .forEach((c) => c.classList.remove("selected"));
                selectedId = id;
                card.classList.add("selected");
            });
            dock?.appendChild(card);
        }

        function startTimer() {
            if (startTime) return;
            startTime = Date.now();
            timerInt = setInterval(() => {
                const elapsed = Math.floor((Date.now() - startTime!) / 1000);
                const m = String(Math.floor(elapsed / 60)).padStart(2, "0");
                const s = String(elapsed % 60).padStart(2, "0");
                if (timerE) timerE.textContent = `${m}:${s}`;
            }, 1000);
        }

        function checkAnswers() {
            const slots = board?.querySelectorAll(".match-slot");
            let correctCount = 0;
            let allFilled = true;

            slots?.forEach((slot) => {
                const s = slot as HTMLElement;
                const placed = s.querySelector(".match-card") as HTMLElement;
                if (!placed) {
                    allFilled = false;
                    return;
                }

                if (placed.dataset.id === s.dataset.targetId) {
                    s.classList.add("correct", "locked");
                    placed.classList.add("locked");
                    correctCount++;
                } else {
                    s.classList.add("wrong");
                    // Auto-return wrong ones after a short delay
                    setTimeout(() => {
                        const id = placed.dataset.id;
                        if (id) returnToDock(id);
                        s.innerHTML = "";
                        s.classList.remove("filled", "wrong");
                    }, 1500);
                }
            });

            if (!allFilled) {
                alert("Por favor, une todas las parejas antes de enviar.");
                slots?.forEach((s) => {
                    if (!s.classList.contains("locked")) {
                        s.classList.remove("correct", "wrong");
                    }
                });
                return;
            }

            if (correctCount === TOTAL) {
                clearInterval(timerInt);
                showModal(true);
            } else {
                showModal(false, correctCount);
            }
        }

        function showModal(isVictory: boolean, correct: number = 0) {
            if (!modal) return;
            const title = document.getElementById("result-title-match");
            const msg = document.getElementById("result-msg-match");
            const icon = document.getElementById("result-icon-match");
            const btn = document.getElementById(
                "close-modal-match",
            ) as HTMLElement;

            if (isVictory) {
                if (title) title.textContent = "¡ESPECTACULAR!";
                if (msg)
                    msg.textContent =
                        "Has dominado todos los conceptos perfectamente.";
                if (icon) icon.textContent = "🏆";
                if (btn) btn.textContent = "CONTINUAR APRENDIENDO";
            } else {
                if (title) title.textContent = "¡CASI LO TIENES!";
                if (msg)
                    msg.textContent = `Has acertado ${correct} de ${TOTAL}. Hemos devuelto los errores a la lista para que lo intentes de nuevo.`;
                if (icon) icon.textContent = "🧐";
                if (btn) btn.textContent = "REINTENTAR ERRORES";
            }

            modal.classList.remove("pointer-events-none", "opacity-0");
            modal.classList.add("opacity-100");
            modal.querySelector("div")?.classList.remove("scale-90");
        }

        function hideModal() {
            if (!modal) return;
            modal.classList.add("pointer-events-none", "opacity-0");
            modal.classList.remove("opacity-100");
            modal.querySelector("div")?.classList.add("scale-90");
        }

        submitBtn?.addEventListener("click", checkAnswers);
        resetBtn?.addEventListener("click", init);
        document
            .getElementById("close-modal-match")
            ?.addEventListener("click", () => {
                const btn = document.getElementById("close-modal-match");
                if (btn?.textContent === "REINTENTAR ERRORES") {
                    hideModal();
                } else {
                    init();
                }
            });

        init();
    })();
</script>
